# Sentry/OpenTelemetry compatibility with pnpm's strict hoisting.
# Prevents "import-in-the-middle" / "require-in-the-middle" external-package
# errors at dev/build time. See Sentry's Next.js troubleshooting docs.
public-hoist-pattern[]=*import-in-the-middle*
public-hoist-pattern[]=*require-in-the-middle*
